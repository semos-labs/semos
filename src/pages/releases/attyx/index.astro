---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";

function compareVersions(a: string, b: string) {
  const pa = a.split(".").map(Number);
  const pb = b.split(".").map(Number);
  for (let i = 0; i < Math.max(pa.length, pb.length); i++) {
    const na = pa[i] ?? 0;
    const nb = pb[i] ?? 0;
    if (na !== nb) return nb - na;
  }
  return 0;
}

const releases = (await getCollection("releases")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime() || compareVersions(a.data.version, b.data.version)
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout title="Attyx Release Notes — Semos Labs">
  <section class="pt-28 md:pt-36 pb-20 md:pb-28 px-6 md:px-8">
    <div class="max-w-[840px] mx-auto">
      <a href="/attyx" class="inline-flex items-center gap-2 text-small text-gray-500 hover:text-gray-300 transition-colors mb-10">
        ← Back to Attyx
      </a>

      <header class="mb-12">
        <div class="flex items-center gap-4 mb-4">
          <img src="/logos/Attyx.png" alt="Attyx" class="w-10 h-10 rounded-lg" />
          <h1 class="heading-display">Release Notes</h1>
        </div>
      </header>

      <ul class="space-y-6">
        {releases.map((release, index) => (
          <li>
            <a
              href={`/releases/attyx/${release.data.version}`}
              class:list={[
                "block group p-5 -mx-5 rounded-xl transition-colors",
                index === 0
                  ? "bg-white/[0.04] ring-1 ring-white/10 hover:bg-white/[0.06]"
                  : "hover:bg-white/[0.03]",
              ]}
            >
              <div class="flex items-baseline justify-between gap-4 mb-1">
                <span class="font-hand text-[1.2rem] text-white group-hover:text-white transition-colors">
                  {release.data.title}
                  {index === 0 && (
                    <span class="ml-3 text-xs font-mono font-normal text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded-full align-middle">
                      Latest
                    </span>
                  )}
                </span>
                <time class="text-small text-gray-500 font-mono shrink-0">
                  {formatDate(release.data.date)}
                </time>
              </div>
              {release.data.summary && (
                <p class="text-body-sm text-gray-400">{release.data.summary}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
